# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# ─── NextAuth ───
NEXTAUTH_URL=https://creditclean.ai
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ─── Owner Login ───
OWNER_EMAIL=tim@makeormaven.com
OWNER_PASSWORD=$2b$10$...  # bcrypt hash

# ─── Email (Resend) ───
RESEND_API_KEY=re_...
EMAIL_FROM=CreditClean AI <noreply@creditclean.ai>
ADMIN_NOTIFICATION_EMAILS=tim@makeormaven.com

# ─── App ───
NEXT_PUBLIC_APP_URL=https://creditclean.ai
